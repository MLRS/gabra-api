{
  "title": "Wordform",
  "type": "object",
  "required" : [
    "lexeme_id",
    "surface_form"
  ],
  "properties": {
    "lexeme_id": {
      "description": "Should be a valid ID in lexemes collection",
      "type": "object"
    },
    "surface_form": {
      "description": "Surface form",
      "examples": [
        "skrejjen"
      ],
      "type": "string"
    },
    "alternatives": {
      "description": "List of spelling alternatives",
      "examples": [
        ["doxxa", "duxxa"]
      ],
      "type": "array",
      "format": "table",
      "items": {
        "title": "alternative",
        "type": "string"
      }
    },
    "gloss": {
      "description": "English gloss",
      "type": "string"
    },
    "sources": {
      "description": "Source keys",
      "examples": [
        ["Spagnol2011", "Falzon2013"]
      ],
      "type": "array",
      "format": "table",
      "items": {
        "title": "source",
        "type": "string"
      }
    },
    "gender": {
      "description": "m (masculine), f (feminine), mf (both masculine and feminine)",
      "type": "string",
      "enum": [
        "m",
        "f",
        "mf"
      ]
    },
    "number": {
      "description": "sg (singular), dl (dual), sgv (singulative), coll (collective), sp (both sg and pl), pl (plural), pl_ind (indeterminate plural - probably not needed), pl_det (determinate plural), pl_pl (plural of plural)",
      "type": "string",
      "enum": [
        "sg",
        "dl",
        "pl",
        "sgv",
        "coll",
        "sp",
        "pl_ind",
        "pl_det",
        "pl_pl"
      ]
    },
    "plural_form": {
      "description": "Plural type",
      "type": "string",
      "enum": [
        "counted"
      ]
    },
    "subject": {
      "description": "Subject agreement (verbs)",
      "examples": [
        { "person":"p3", "number":"sg", "gender":"m" }
      ],
      "$ref": "#/definitions/agr",
      "title": "subject"
    },
    "dir_obj": {
      "description": "Direct object agreement",
      "examples": [
        { "person":"p3", "number":"pl" }
      ],
      "$ref": "#/definitions/agr",
      "title": "direct object"
    },
    "ind_obj": {
      "description": "Indirect object agreement",
      "examples": [
        { "person":"p1", "number":"pl" }
      ],
      "$ref": "#/definitions/agr",
      "title": "indirect object"
    },
    "possessor": {
      "description": "Agreement for nouns which inflect for possessive",
      "examples": [
        { "person":"p3", "number":"sg", "gender":"m" }
      ],
      "$ref": "#/definitions/agr",
      "title": "possessor"
    },
    "form": {
      "description": "General morphological form",
      "type": "string",
      "enum": [
        "comparative",
        "superlative",
        "diminutive",
        "interrogative",
        "mimated",
        "verbalnoun"
      ]
    },
    "aspect": {
      "description": "Aspect (verbs)",
      "type": "string",
      "enum": [
        "perf",
        "impf",
        "imp",
        "pastpart",
        "prespart"
      ]
    },
    "polarity": {
      "type": "string",
      "enum": [
        "pos",
        "neg"
      ]
    },
    "stem": {
      "type": "string"
    },
    "phonetic": {
      "description": "Phonetic transcription",
      "examples": [
        "'skrɛjjɛn"
      ],
      "type": "string"
    },
    "pattern": {
      "description": "Vowel-consonant pattern",
      "examples": [
        "CCVVCVC"
      ],
      "type": "string"
    },
    "hypothetical": {
      "type": "boolean",
      "format": "checkbox"
    },
    "archaic": {
      "type": "boolean",
      "format": "checkbox"
    },
    "generated": {
      "description": "Wordform was auto-generated",
      "type": "boolean"
    },
    "pending": {
      "description": "Flagged as incorrect or new suggestion",
      "type": "boolean",
      "format": "checkbox"
    }
  },
  "definitions": {
    "agr": {
      "description": "Agreement",
      "type": ["null","object"],
      "required": [
        "person",
        "number"
      ],
      "properties": {
        "person": {
          "type": ["null","string"],
          "enum": [
            null,
            "p1",
            "p2",
            "p3"
          ]
        },
        "number": {
          "type": "string",
          "enum": [
            "sg",
            "pl"
          ]
        },
        "gender": {
          "type": "string",
          "enum": [
            "m",
            "f",
            "mf"
          ]
        }
      }
    }
  }
}
